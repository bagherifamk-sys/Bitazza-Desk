# Google Gemini
GEMINI_API_KEY=API_KEY
FRESHDESK_API_KEY=your_freshdesk_api_key_here
FRESHDESK_SUBDOMAIN=yourcompany.freshdesk.com

# Yellow.ai
YELLOWAI_API_KEY=your_yellowai_api_key_here
YELLOWAI_BOT_ID=your_yellowai_bot_id_here

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/csbot

# Vector DB
CHROMA_PATH=./data/chroma

# Auth
JWT_SECRET=your_jwt_secret_here

# User / KYC API
# Set USE_MOCK_USER_API=false and fill in the real values when going live.
# The real API requires an API key sent as a Bearer token; access is also
# restricted by IP whitelist on the provider's side.
USE_MOCK_USER_API=true
USER_API_BASE_URL=http://localhost:8000
USER_API_KEY=mock-dev-token

# Environment — set to "production" in prod to enforce strict auth
ENV=development

# App
ESCALATION_CONFIDENCE_THRESHOLD=0.6
MAX_RAG_CHUNKS=5
RATE_LIMIT_PER_MINUTE=20
